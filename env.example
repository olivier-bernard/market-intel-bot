# Market Intelligence RAG System - Environment Template
# Copy this to .env and fill in your values
# NEVER commit .env to git - add to .gitignore

# ===== LLM PROVIDER =====
# Choose: "claude" or "ollama"
LLM_PROVIDER=claude

# Claude API (required if LLM_PROVIDER=claude)
CLAUDE_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get from: https://console.anthropic.com/account/keys

# Ollama (required if LLM_PROVIDER=ollama)
OLLAMA_HOST=http://my_ollama_server:11434
OLLAMA_MODEL=mistral
# Others: neural-chat:7b, mixtral:8x7b, qwen2.5-coder

# ===== VECTOR DATABASE =====
QDRANT_HOST=my_qdran_server
QDRANT_PORT=6333
# Optional: QDRANT_API_KEY=xxxx  (if using Qdrant Cloud)

# ===== EMBEDDINGS =====
# Choose: "ollama" or "openai"
EMBED_PROVIDER=ollama
EMBED_MODEL=nomic-embed-text

# OpenAI (required if EMBED_PROVIDER=openai)
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== EMAIL DISTRIBUTION =====
# Brevo (formerly Sendinblue) for transactional email
BREVO_EMAIL_API_URL=https://api.brevo.com/v3/smtp/email
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Get from: https://app.brevo.com/settings/account/api

EMAIL_SENDER=noreply@company.com
EMAIL_SENDER_NAME=Market Intelligence

# ===== NEXTCLOUD INTEGRATION =====
NEXTCLOUD_URL=my_nextcloud_instance
NEXTCLOUD_USER=marketbot
NEXTCLOUD_PASS=your-secure-password-or-token

# Channel tokens (extract from: https://my_nextcloud_instance/call/{TOKEN})
NC_BOT_CHANNEL_PRIVATE=channel_id
NC_BOT_CHANNEL_PUBLIC=public-token

